                            <ul id="vocabList" class="text-sm text-gray-600 space-y-1"></ul>
                        </div>
                    </div>
                </div>

                <!-- 底部导航按钮 -->
                <div class="flex justify-between mt-6">
                    <button id="prevBtn" class="px-6 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition font-medium disabled:opacity-50 disabled:cursor-not-allowed">
                        上一题
                    </button>
                    <button id="nextBtn" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium disabled:opacity-50 disabled:cursor-not-allowed">
                        下一题
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
