            {
                id: 241,
                question: "Employers in the financial sector value graduates with the ability to continuously________ their knowledge.",
                options: { A: "upload", B: "upset", C: "update", D: "recruit" },
                answer: "C",
                analysis: "本题考查动词词义辨析。句意为\"金融行业的雇主看重那些能够不断更新知识的毕业生\"。update their knowledge为常用搭配，意为\"更新知识\"，符合终身学习的职场要求。upload意为\"上传\"；upset意为\"打乱，使不安\"；recruit意为\"招聘\"，均不符合句意。",
                vocabulary: [
                    {word: "update", meaning: "v. 更新，使现代化"}, {word: "financial sector", meaning: "金融行业"}, {word: "continuously", meaning: "adv. 持续地，不断地"}
                ]
            }
        
        ];

        // ===================== 全局状态 =====================
        let currentIndex = 0;
        let userAnswers = new Array(questions.length).fill(null); // 存储用户答案
        let score = 0;
        let wrongCount = 0;

        // ===================== DOM 元素 =====================
        const questionText = document.getElementById('questionText');
        const optionsContainer = document.getElementById('optionsContainer');
        const resultArea = document.getElementById('resultArea');
        const resultTip = document.getElementById('resultTip');
        const analysisText = document.getElementById('analysisText');
        const vocabList = document.getElementById('vocabList');
        const currentNum = document.getElementById('currentNumSmall');
        const progressText = document.getElementById('progressText');
        const scoreText = document.getElementById('scoreText');
        const wrongCountText = document.getElementById('wrongCount');
        const progressBar = document.getElementById('progressBar');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const questionNav = document.getElementById('questionNav');
        const exportBtn = document.getElementById('exportBtn');

        // ===================== 初始化 =====================
        function init() {
            renderNav();
            renderQuestion();
            updateStatus();
        }

        // 渲染题号导航
        function renderNav() {
            questionNav.innerHTML = '';
            questions.forEach((q, index) => {
                const dot = document.createElement('div');
                dot.className = 'nav-dot';
                dot.textContent = index + 1;
                dot.onclick = () => {
                    currentIndex = index;
                    renderQuestion();
                    updateNavStatus();
                };
                questionNav.appendChild(dot);
            });
            updateNavStatus();
        }

        // 更新导航点状态
        function updateNavStatus() {
            const dots = questionNav.querySelectorAll('.nav-dot');
            dots.forEach((dot, index) => {
                dot.classList.remove('current', 'done-correct', 'done-wrong');
                if (index === currentIndex) {
                    dot.classList.add('current');
                } else if (userAnswers[index] !== null) {
                    if (userAnswers[index] === questions[index].answer) {
                        dot.classList.add('done-correct');
                    } else {
                        dot.classList.add('done-wrong');
                    }
                }
            });
        }

        // 渲染当前题目
        function renderQuestion() {
            const q = questions[currentIndex];
            currentNum.textContent = q.id;
            questionText.textContent = q.question;

            // 渲染选项
            optionsContainer.innerHTML = '';
            Object.keys(q.options).forEach(key => {
                const btn = document.createElement('button');
                btn.className = 'option-btn w-full p-3 border border-gray-200 rounded-lg bg-white text-gray-700 font-medium';
                btn.innerHTML = `<span class="font-bold mr-2">${key}.</span> ${q.options[key]}`;
                
                // 如果已经答过，显示状态
                if (userAnswers[currentIndex] !== null) {
                    btn.disabled = true;
                    if (key === q.answer) {
                        btn.classList.add('correct-opt');
                    } else if (key === userAnswers[currentIndex] && key !== q.answer) {
                        btn.classList.add('wrong-opt');
                    }
                } else {
                    btn.onclick = () => selectOption(key);
                }
                
                optionsContainer.appendChild(btn);
            });

            // 如果已经答过，显示解析
            if (userAnswers[currentIndex] !== null) {
                showAnalysis();
            } else {
                resultArea.classList.add('hidden');
            }

            // 更新按钮状态
            prevBtn.disabled = currentIndex === 0;
            nextBtn.disabled = currentIndex === questions.length - 1;
        }

        // 选择选项
        function selectOption(key) {
            const q = questions[currentIndex];
            userAnswers[currentIndex] = key;

            // 更新分数
            const answeredCount = userAnswers.filter(a => a !== null).length;
            wrongCount = userAnswers.filter((a, i) => a !== null && a !== questions[i].answer).length;
            score = (answeredCount - wrongCount) * 0.5;

            // 更新选项样式
            const btns = optionsContainer.querySelectorAll('.option-btn');
            btns.forEach(btn => btn.disabled = true);
            
            // 找到点击的按钮和正确答案按钮
            btns.forEach(btn => {
                const optKey = btn.textContent.trim().charAt(0);
                if (optKey === q.answer) {
                    btn.classList.add('correct-opt');
                } else if (optKey === key && key !== q.answer) {
                    btn.classList.add('wrong-opt');
                }
            });

            // 显示解析
            showAnalysis();
            
            // 更新状态
            updateStatus();
            updateNavStatus();

            // 回答正确则自动跳转到下一题（延迟0.8秒）
            const qq = questions[currentIndex];
            if (key === qq.answer && currentIndex < questions.length - 1) {
                setTimeout(() => {
                    currentIndex++;
                    renderQuestion();
                    updateNavStatus();
                    // 滚动到题目区域
                    document.querySelector('.flex-1').scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 800);
            }
        }

        // 显示解析
        function showAnalysis() {
            const q = questions[currentIndex];
            const isCorrect = userAnswers[currentIndex] === q.answer;
            
            resultTip.textContent = isCorrect ? '✅ 回答正确！' : '❌ 回答错误';
            resultTip.className = isCorrect ? 'font-bold text-lg mb-3 text-green-600' : 'font-bold text-lg mb-3 text-red-600';
            
            analysisText.textContent = q.analysis;
            
            vocabList.innerHTML = '';
            q.vocabulary.forEach(item => {
                const li = document.createElement('li');
                li.innerHTML = `<strong>${item.word}</strong>：${item.meaning}`;
                vocabList.appendChild(li);
            });

            resultArea.classList.remove('hidden');
        }

        // 更新顶部状态
        function updateStatus() {
            const answeredCount = userAnswers.filter(a => a !== null).length;
            progressText.textContent = `${answeredCount}/${questions.length}`;
            scoreText.textContent = score.toFixed(1);
            wrongCountText.textContent = wrongCount;
            progressBar.style.width = `${(answeredCount / questions.length) * 100}%`;
        }

        // 上一题
        prevBtn.onclick = () => {
            if (currentIndex > 0) {
                currentIndex--;
                renderQuestion();
                updateNavStatus();
            }
        };

        // 下一题
        nextBtn.onclick = () => {
            if (currentIndex < questions.length - 1) {
                currentIndex++;
                renderQuestion();
                updateNavStatus();
            }
        };

        // ===================== 导出错题 Word 文档 =====================
        exportBtn.onclick = () => {
            const wrongQuestions = questions.filter((q, index) => 
                userAnswers[index] !== null && userAnswers[index] !== q.answer
            );

            if (wrongQuestions.length === 0) {
                alert('暂无错题，继续加油！');
                return;
            }

            // 构建 HTML 格式的 Word 文档
            let html = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">';
            html += '<head><meta charset="utf-8"><title>英语单选错题本</title>';
            html += '<style>';
            html += 'body{font-family:Microsoft YaHei,Arial,sans-serif;font-size:12pt;padding:30px;}';
            html += 'h1{text-align:center;font-size:20pt;color:#1a73e8;}';
            html += 'h2{font-size:14pt;margin-top:20px;color:#333;}';
            html += '.q{margin:10px 0 5px 0;font-size:12pt;}';
            html += '.opt{margin-left:25px;font-size:11pt;color:#555;}';
            html += '.info{color:#c0392b;margin:8px 0;}';
            html += '.analysis{margin:8px 0;padding:10px;background:#f5f5f5;border-radius:4px;font-size:11pt;}';
            html += '.vocab{margin-left:25px;font-size:10pt;color:#1a73e8;}';
            html += '.hr{border:none;border-top:1px dashed #ccc;margin:20px 0;}';
            html += '</style></head><body>';

            html += '<h1>📝 英语单选错题本</h1>';
            html += '<p style="text-align:center;color:#666;font-size:11pt;">共 ' + wrongQuestions.length + ' 道错题</p>';
            html += '<hr style="border:none;border-top:2px solid #1a73e8;margin:20px 0;">';

            wrongQuestions.forEach((q, idx) => {
                const userAns = userAnswers[questions.indexOf(q)];
                html += '<h2>' + (idx + 1) + '. ' + q.question + '</h2>';
                
                Object.keys(q.options).forEach(key => {
                    let mark = '';
                    if (key === q.answer && key === userAns) mark = ' ← 你的选择 ✅';
                    else if (key === userAns) mark = ' ← 你的选择 ❌';
                    else if (key === q.answer) mark = ' ✅';
                    html += '<div class="opt">' + key + '. ' + q.options[key] + mark + '</div>';
                });

                html += '<div class="info"><b>你的答案：</b>' + userAns + '　　<b>正确答案：</b>' + q.answer + '</div>';
                html += '<div class="analysis"><b>📖 解析：</b>' + q.analysis + '</div>';
                
                html += '<div style="margin-top:5px;"><b>📚 重点词汇：</b></div>';
                q.vocabulary.forEach(item => {
                    html += '<div class="vocab">• <b>' + item.word + '</b>：' + item.meaning + '</div>';
                });

                if (idx < wrongQuestions.length - 1) {
                    html += '<hr class="hr">';
                }
            });

            html += '<p style="text-align:center;color:#999;font-size:10pt;margin-top:30px;">—— 由在线答题系统生成 ——</p>';
            html += '</body></html>';

            try {
                var blob = new Blob(['\ufeff' + html], { type: 'application/msword' });
                saveAs(blob, '英语单选错题本.doc');
                alert('✅ 错题已导出为 "英语单选错题本.doc"，共 ' + wrongQuestions.length + ' 道错题');
            } catch (e) {
                // 降级方案：直接下载
                var a = document.createElement('a');
                a.href = 'data:application/msword;charset=utf-8,' + encodeURIComponent('\ufeff' + html);
                a.download = '英语单选错题本.doc';
                a.click();
                alert('✅ 错题已导出为 "英语单选错题本.doc"，共 ' + wrongQuestions.length + ' 道错题');
            }
        };

        // 启动
        init();
    </script>
</body>
</html>
