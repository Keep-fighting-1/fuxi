            <div class="w-full bg-gray-200 rounded-full h-2">
                <div id="progressBar" class="bg-blue-600 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
        </div>

        <!-- 题号导航（固定在最左侧） -->
        <div class="nav-wrapper">
            <div class="flex items-center justify-between mb-2 px-1">
                <span class="text-xs font-medium text-gray-500">题号</span>
                <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded-full font-medium">
                    <span id="currentNumSmall">1</span>/241
                </span>
            </div>
            <div id="questionNav" class="question-nav"></div>
        </div>

        <!-- 题目主区域 -->
        <div class="main-area">
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="mb-4">
                        <h2 id="questionText" class="text-lg font-medium text-gray-800 leading-relaxed"></h2>
                    </div>

                    <div id="optionsContainer" class="space-y-3 mb-6">
